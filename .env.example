# Cadena de conexión de tu base de datos Postgres (la copiás de Neon)
DATABASE_URL=postgres://usuario:password@host/nombre_basedatos?sslmode=require

# Clave secreta para firmar las sesiones. Generala con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambiar-por-una-clave-larga-y-aleatoria
